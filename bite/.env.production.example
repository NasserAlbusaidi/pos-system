# Bite-POS — Forge pilot production env (getbite.om on DO Bangalore).
# Copy into Forge → Site → Environment, fill every <PLACEHOLDER>. Never commit real
# secrets. Full runbook: docs/DEPLOYMENT-FORGE.md

APP_NAME="Bite POS"
APP_ENV=production
APP_KEY=                          # php artisan key:generate --show
APP_DEBUG=false
APP_URL=https://getbite.om
SOURDOUGH_ADMIN_PASSWORD=<set-strong-handoff-password-before-seeding>

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

# HTTPS behind Forge nginx (Let's Encrypt terminates TLS).
FORCE_HTTPS=true
# Leave TRUSTED_PROXIES unset — Forge nginx forwards from loopback, already trusted
# by bootstrap/app.php. Set it ONLY if Cloudflare is flipped to orange (proxied),
# using Cloudflare's CIDRs, or rate-limit + loyalty key off the wrong IP.
# TRUSTED_PROXIES=

# Database — Forge-provisioned MySQL 8 on the same box.
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=getbite
DB_USERNAME=forge
DB_PASSWORD=<set-in-forge>

# Sessions / cache / queue — DB-backed. Queue stays sync: pilot dispatches no async
# jobs (matches the Dockerfile pin), so no worker daemon is needed.
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=lax
SESSION_PATH=/
SESSION_DOMAIN=null
CACHE_STORE=database
QUEUE_CONNECTION=sync

# Storage — LOCAL public disk (served via `php artisan storage:link`).
# NOT 'gcs' (legacy Cloud Run) and NOT 'local' (writes to storage/app/private,
# where productImage() URLs can't resolve).
FILESYSTEM_DISK=public

# Mail — pilot sends ~no email (orders go database + WhatsApp). Keep `log` until you
# wire Resend on a send.getbite.om subdomain. See DEPLOYMENT-FORGE.md §1.5.
MAIL_MAILER=log
MAIL_FROM_ADDRESS="noreply@getbite.om"
MAIL_FROM_NAME="${APP_NAME}"

# Customer order payments — pay-at-counter pilot. No online guest payment.
PAYMENT_PROVIDER=counter

# Stripe Billing — required for Pro subscriptions and the billing portal.
STRIPE_KEY=<set-in-forge>
STRIPE_SECRET=<set-in-forge>
CASHIER_CURRENCY=omr
CASHIER_CURRENCY_LOCALE=en_OM
STRIPE_PRO_PRICE_ID=<set-in-stripe>
STRIPE_SUBSCRIPTION_WEBHOOK_SECRET=<set-from-stripe-endpoint>
# Optional until online customer payments are enabled.
STRIPE_WEBHOOK_SECRET=

# AI — Snap-to-Menu (admin convenience; optional).
GEMINI_API_KEY=

# Error tracking — required in prod because startup validation fails without it.
SENTRY_LARAVEL_DSN=<set-in-sentry>
SENTRY_TRACES_SAMPLE_RATE=0.1

# WhatsApp — new-order alerts (configure if used).
# WHATSAPP_...

VITE_APP_NAME="${APP_NAME}"
