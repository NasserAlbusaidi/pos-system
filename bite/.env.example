APP_NAME="Bite POS"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Database — use MySQL 8.0 in production
DB_CONNECTION=sqlite
# DB_CONNECTION=mysql
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=bite_pos
# DB_USERNAME=bite
# DB_PASSWORD=

# Session — encryption enabled by default
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=null
# SESSION_SECURE_COOKIE=true    # Enable in production (HTTPS only)
# SESSION_SAME_SITE=strict      # Tighten in production if no cross-site iframes

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Mail — configure for transactional email in production
# Recommended: Resend, Postmark, or Mailgun
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@bitepos.app"
MAIL_FROM_NAME="${APP_NAME}"

# AWS S3 — for product image storage in production
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=me-south-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# PrintNode — thermal receipt/kitchen ticket printing
PRINTNODE_ENABLED=false
PRINTNODE_API_KEY=
PRINTNODE_PRINTER_ID=
PRINTNODE_ENDPOINT=https://api.printnode.com

# Stripe — payment processing
PAYMENT_PROVIDER=stripe
STRIPE_WEBHOOK_SECRET=

# Stripe Billing (Laravel Cashier) — subscription management
STRIPE_KEY=
STRIPE_SECRET=
CASHIER_CURRENCY=omr
CASHIER_CURRENCY_LOCALE=en_OM
STRIPE_FREE_PRICE_ID=
STRIPE_PRO_PRICE_ID=
STRIPE_SUBSCRIPTION_WEBHOOK_SECRET=

# Force HTTPS in production (set to true behind a reverse proxy)
# FORCE_HTTPS=true
