APP_NAME="Bite POS"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
# Local dev serves on :8000 (composer dev / artisan serve). APP_URL MUST include
# the port — public-disk image URLs are built from it, so a bare http://localhost
# makes every product photo 404. In production set this to the real domain.
APP_URL=http://localhost:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

# Trusted proxies for resolving the real client IP (request()->ip()), which
# gates rate limiting, loyalty, and abuse controls. Leave UNSET for the safe
# default that trusts only loopback + RFC1918 private ranges — correct for a
# same-host nginx reverse proxy (e.g. the Forge VPS). On the VPS, set this to
# the reverse proxy's real IP/CIDR. Use "*" ONLY behind a managed front end
# (e.g. Cloud Run / load balancer) whose app port is unreachable publicly;
# "*" lets any client spoof X-Forwarded-For if the port is exposed.
# TRUSTED_PROXIES=127.0.0.1

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Production secrets (Forge environment variables):
# APP_KEY, DB_PASSWORD, STRIPE_SECRET, STRIPE_KEY,
# STRIPE_SUBSCRIPTION_WEBHOOK_SECRET,
# SENTRY_LARAVEL_DSN, GEMINI_API_KEY
# STRIPE_WEBHOOK_SECRET is required only when PAYMENT_PROVIDER=stripe
# enables online guest payments.
# Forge pilot production values live in .env.production.example.

# Database — MySQL 8.0 on Forge in production, local MySQL or SQLite for dev
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=bite_pos
DB_USERNAME=bite
DB_PASSWORD=

# Legacy Cloud Run reference: Cloud SQL Auth Proxy socket.
# DB_SOCKET=/cloudsql/PROJECT_ID:REGION:INSTANCE_NAME

# Session — encryption enabled by default
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=null
# SESSION_SECURE_COOKIE=true    # Enable in production (HTTPS only)
# SESSION_SAME_SITE=strict      # Tighten in production if no cross-site iframes

BROADCAST_CONNECTION=log
# Product images are public web assets served from the 'public' disk via
# `php artisan storage:link`. The Forge pilot runs production on this same local
# disk (#18), so keep FILESYSTEM_DISK=public there too. 'gcs' is the legacy
# Cloud Run option (commented out below). Do NOT use 'local' — it writes to
# storage/app/private, where productImage() URLs can't resolve.
FILESYSTEM_DISK=public
# Forge pilot and local smoke runs dispatch no async jobs. Keep this sync unless
# a real queue worker is provisioned and covered by the deployment runbook.
QUEUE_CONNECTION=sync

CACHE_STORE=database

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Mail — configure for transactional email in production
# Recommended: Resend, Postmark, or Mailgun
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@bitepos.app"
MAIL_FROM_NAME="${APP_NAME}"

# AWS S3 — for product image storage in production
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=me-south-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# PrintNode — thermal receipt/kitchen ticket printing
PRINTNODE_ENABLED=false
PRINTNODE_API_KEY=
PRINTNODE_PRINTER_ID=
PRINTNODE_ENDPOINT=https://api.printnode.com

# Customer order payments — counter means pay-at-counter/no online guest capture.
# Use stripe only when online guest payments are enabled and STRIPE_WEBHOOK_SECRET
# is configured in Stripe.
PAYMENT_PROVIDER=counter
STRIPE_WEBHOOK_SECRET=

# Stripe Billing (Laravel Cashier) — subscription management
STRIPE_KEY=
STRIPE_SECRET=
CASHIER_CURRENCY=omr
CASHIER_CURRENCY_LOCALE=en_OM
STRIPE_FREE_PRICE_ID=
STRIPE_PRO_PRICE_ID=
STRIPE_SUBSCRIPTION_WEBHOOK_SECRET=

# Sentry — error tracking
SENTRY_LARAVEL_DSN=
SENTRY_TRACES_SAMPLE_RATE=

# Google Gemini — AI menu extraction (Snap-to-Menu)
GEMINI_API_KEY=

# Legacy Cloud Run reference: Google Cloud Storage product images and uploads.
GOOGLE_CLOUD_PROJECT_ID=
GCS_BUCKET=
# GCS_PATH_PREFIX=                   # Optional: prefix for all stored files
# FILESYSTEM_DISK=gcs                # Legacy Cloud Run only; Forge uses public
# LIVEWIRE_TEMP_DISK=gcs             # Legacy Cloud Run only; Forge uses public

# Force HTTPS in production (set to true behind a reverse proxy)
# FORCE_HTTPS=true
